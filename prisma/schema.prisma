generator client {
  provider = "prisma-client-js"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FormType {
  CHEM
  OGTT
  CBC
  BT
  UA
  SE
  PT
  OBT
  IMMUNO
  MICRO
}

model Profile {
  id        String        @id
  userIdNum String        @unique
  firstName String?
  lastName  String?
  role      Role          @default(USER)
  status    AccountStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  patientSessions PatientSession[] @relation("ProfilePatientSessions")
  formEditLocks   FormEditLock[]   @relation("ProfileEditLocks")
}

model PatientSession {
  id              String   @id @default(cuid())
  createdByUserId String
  patientData     Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy Profile @relation("ProfilePatientSessions", fields: [createdByUserId], references: [id], onDelete: Restrict)

  labForms      LabForm[]
  formEditLocks FormEditLock[]

  @@index([createdByUserId])
  @@index([updatedAt])
}

model LabForm {
  id               String   @id @default(cuid())
  patientSessionId String
  formType         FormType
  data             Json     @default("{}")
  version          Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  patientSession PatientSession @relation(fields: [patientSessionId], references: [id], onDelete: Cascade)

  @@unique([patientSessionId, formType])
  @@index([updatedAt])
}

model FormEditLock {
  id               String   @id @default(cuid())
  patientSessionId String
  formType         FormType
  lockedByUserId   String
  lockToken        String
  expiresAt        DateTime
  updatedAt        DateTime @updatedAt

  patientSession PatientSession @relation(fields: [patientSessionId], references: [id], onDelete: Cascade)
  lockedBy       Profile        @relation("ProfileEditLocks", fields: [lockedByUserId], references: [id], onDelete: Restrict)

  @@unique([patientSessionId, formType])
  @@index([expiresAt])
  @@index([updatedAt])
}
